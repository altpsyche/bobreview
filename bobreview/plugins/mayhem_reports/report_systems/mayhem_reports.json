{
    "schema_version": "1.0",
    "id": "mayhem_reports",
    "name": "Performance Analysis Report",
    "version": "1.0.0",
    "description": "Game performance analysis from PNG filename metadata. Extracts triangle counts, draw calls, and timestamps from filename patterns.",
    "author": "BobReview Team",
    "tags": [
        "game",
        "performance",
        "graphics",
        "rendering"
    ],
    "data_source": {
        "type": "mayhem_reports_parser",
        "input_format": "png",
        "pattern": "{testcase}_{tris}_{draws}_{timestamp}.png",
        "fields": {
            "testcase": {
                "type": "string",
                "required": true
            },
            "tris": {
                "type": "integer",
                "required": true,
                "min": 0
            },
            "draws": {
                "type": "integer",
                "required": true,
                "min": 0
            },
            "timestamp": {
                "type": "integer",
                "required": true,
                "min": 0
            }
        },
        "validation": {
            "allow_missing_fields": false,
            "skip_invalid": true,
            "strict_mode": false
        }
    },
    "extensions": {
        "metrics": {
            "primary": [
                "draws",
                "tris"
            ],
            "metric_labels": {
                "draws": "Draw Calls",
                "tris": "Triangle Count"
            },
            "threshold_mapping": {
                "draws": {
                    "soft_cap": "draw_soft_cap",
                    "hard_cap": "draw_hard_cap",
                    "high": "high_load_draw_threshold",
                    "low": "low_load_draw_threshold"
                },
                "tris": {
                    "soft_cap": "tri_soft_cap",
                    "hard_cap": "tri_hard_cap",
                    "high": "high_load_tri_threshold",
                    "low": "low_load_tri_threshold"
                }
            },
            "timestamp_field": "ts",
            "identifier_field": "testcase"
        }
    },
    "thresholds": {
        "draw_soft_cap": 550,
        "draw_hard_cap": 600,
        "tri_soft_cap": 100000,
        "tri_hard_cap": 120000,
        "high_load_draw_threshold": 600,
        "high_load_tri_threshold": 100000,
        "low_load_draw_threshold": 400,
        "low_load_tri_threshold": 50000,
        "outlier_sigma": 2.0,
        "mad_threshold": 3.5
    },
    "title": "Performance Analysis Report",
    "labels": {
        "draw_calls": "Draw Calls",
        "triangles": "Triangles",
        "executive_summary": "Performance Overview",
        "quick_stats": "Key Metrics",
        "high_load": "Hotspots",
        "low_load": "Optimized",
        "home": "Overview",
        "metrics": "Metrics",
        "zones": "Hotspots",
        "visuals": "Visuals",
        "optimization": "Optimization",
        "stats": "Details",
        "performance_grade": "Performance Grade",
        "budget_utilization": "Budget Usage",
        "p90": "Heavy Load (90%)",
        "p95": "Very Heavy (95%)",
        "p99": "Worst Case",
        "trend": "Performance Trend",
        "high_variance_detected": "Inconsistent Performance",
        "detailed_analysis": "Deep Dive Analysis",
        "footer_text": "Generated by BobReview - Game Performance Analysis"
    },
    "llm_config": {
        "provider": "openai",
        "model": "gpt-4o",
        "temperature": 0.7,
        "max_tokens": 2000,
        "chunk_size": 10,
        "enable_cache": true
    },
    "llm_generators": [
        {
            "id": "executive_summary",
            "name": "Performance Overview",
            "description": "Game developer-friendly performance overview and actionable insights",
            "prompt_template": "You are a game performance analyst writing for game developers and artists. Generate a clear, actionable performance overview.\n\n**IMPORTANT: Avoid stats jargon.** Use plain language:\n- 'typical' or 'average' instead of 'mean/median'\n- 'heavy load' or 'worst cases' instead of 'P90/P95'\n- 'consistent/inconsistent' instead of 'low/high variance'\n- 'spikes' instead of 'outliers'\n\nData summary:\n- Total captures: {stats.count}\n- Draw Calls: typically {stats.draws.mean}, worst {stats.draws.p99}\n- Triangles: typically {stats.tris.mean}, worst {stats.tris.p99}\n\nFocus on:\n1. Performance Health - Are we hitting frame budget?\n2. Optimization Opportunities - What needs attention?\n3. Recommended Actions - What should the team focus on?\n\n**FORMATTING:** Use **Markdown**: **bold** for key metrics, bullet points for recommendations. Be concise and actionable.",
            "data_table": {
                "columns": [
                    "index",
                    "testcase",
                    "draws",
                    "tris",
                    "timestamp"
                ],
                "sample_strategy": "mixed",
                "samples": {
                    "critical": 1,
                    "high_load": 2,
                    "low_load": 1,
                    "random": 3
                },
                "max_rows": 10
            },
            "returns": "string",
            "enabled": true
        }
    ],
    "pages": [
        {
            "id": "home",
            "filename": "index.html",
            "nav_label": "Overview",
            "nav_order": 10,
            "template": {
                "type": "jinja2",
                "name": "mayhem_reports/pages/home.html.j2"
            },
            "llm_mappings": {
                "exec_summary": "executive_summary"
            },
            "llm_content": [
                "executive_summary"
            ],
            "data_requirements": {
                "data_points": false,
                "images": false
            },
            "features": {
                "navigation_cards": true,
                "summary_stats": true
            },
            "enabled": true
        }
    ],
    "theme": {
        "preset": "terminal"
    },
    "output": {
        "default_filename": "performance_report.html",
        "embed_images": true,
        "linked_css": false
    },
    "content_blocks": {
        "quick_stats": [
            {
                "label": "Total Captures",
                "value": "{stats.count}"
            },
            {
                "label": "Draw Calls Range",
                "value": "{stats.draws.min} - {stats.draws.max}"
            },
            {
                "label": "Triangles Range",
                "value": "{stats.tris.min} - {stats.tris.max}"
            },
            {
                "label": "High-Load Frames",
                "value": "{high_load_count}"
            },
            {
                "label": "Low-Load Frames",
                "value": "{low_load_count}"
            },
            {
                "label": "Performance Variance",
                "value": "{stats.draws.cv}%"
            }
        ]
    }
}