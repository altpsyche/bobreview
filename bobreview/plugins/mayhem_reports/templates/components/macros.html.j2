{#
  Jinja2 Macros for mayhem-reports Plugin.
  
  UI components for performance reports.
  All macros use theme CSS variables for consistent styling.
#}

{#- Stat Card Component -#}
{% macro stat_card(label, value, subtitle='', variant='') %}
<div class="stat-card{% if variant %} stat-card--{{ variant }}{% endif %}">
  <div class="stat-card-label">{{ label }}</div>
  <div class="stat-card-value">{{ value }}</div>
  {% if subtitle %}
  <div class="stat-card-sub">{{ subtitle }}</div>
  {% endif %}
</div>
{% endmacro %}


{#- Stats Item Component (for stats grid) -#}
{% macro stats_item(label, value) %}
<div class="stats-item">
  <div class="stats-item-label">{{ label }}</div>
  <div class="stats-item-value">{{ value }}</div>
</div>
{% endmacro %}


{#- Trend Indicator Component -#}
{% macro trend_indicator(direction, label='') %}
{% set icon = 'fa-arrow-up' if direction == 'improving' else ('fa-arrow-down' if direction == 'degrading' else 'fa-minus') %}
{% set color_class = 'trend--improving' if direction == 'improving' else ('trend--degrading' if direction == 'degrading' else 'trend--stable') %}
<span class="trend-indicator {{ color_class }}" title="{{ label }}">
  <i class="fas {{ icon }}"></i>
  {% if label %}<span class="trend-label">{{ label }}</span>{% endif %}
</span>
{% endmacro %}


{#- Pill Badge Component -#}
{% macro pill(text, variant='default') %}
<span class="pill pill--{{ variant }}">{{ text }}</span>
{% endmacro %}


{#- Percentile Badge Component -#}
{% macro percentile_badge(label, value, threshold=None) %}
{% set variant = 'danger' if threshold and value > threshold else 'default' %}
<span class="percentile-badge percentile-badge--{{ variant }}">
  <span class="percentile-label">{{ label }}</span>
  <span class="percentile-value">{{ value|int }}</span>
</span>
{% endmacro %}


{#- Feature Card Component (for navigation cards) -#}
{% macro feature_card(url, icon, title, description, pills=[]) %}
<a href="{{ url }}" class="feature-card">
  <div class="feature-card-icon">
    <i class="fas {{ icon }}"></i>
  </div>
  <div class="feature-card-content">
    <h3>{{ title }}</h3>
    <p>{{ description }}</p>
    {% if pills %}
    <div class="feature-card-pills">
      {% for pill_text, pill_variant in pills %}
      {{ pill(pill_text, pill_variant) }}
      {% endfor %}
    </div>
    {% endif %}
  </div>
  <div class="feature-card-arrow">
    <i class="fas fa-chevron-right"></i>
  </div>
</a>
{% endmacro %}


{#- Metric Table Component -#}
{% macro metric_table(metric_name, stats, labels) %}
<table>
  <thead>
    <tr>
      <th>{{ labels.get('metric', 'Metric') }}</th>
      <th>{{ labels.get('value', 'Value') }}</th>
    </tr>
  </thead>
  <tbody>
    <tr><td>{{ labels.get('minimum', 'Min') }}</td><td>{{ stats.min|format_number }}</td></tr>
    <tr><td>{{ labels.get('q1_label', 'Light Load (25%)') }}</td><td>{{ stats.q1|format_number(0) }}</td></tr>
    <tr><td>{{ labels.get('q2_label', 'Typical Load') }}</td><td>{{ stats.median|format_number(0) }}</td></tr>
    <tr><td>{{ labels.get('q3_label', 'Heavy Load (75%)') }}</td><td>{{ stats.q3|format_number(0) }}</td></tr>
    <tr><td>{{ labels.get('maximum', 'Max') }}</td><td>{{ stats.max|format_number }}</td></tr>
    <tr><td>{{ labels.get('mean', 'Average') }}</td><td>{{ stats.mean|format_number(1) }}</td></tr>
    <tr><td>{{ labels.get('standard_deviation', 'Typical Spread') }}</td><td>{{ stats.stdev|format_number(1) }}</td></tr>
    <tr><td>{{ labels.get('cv', 'Stability') }}</td><td>{{ stats.cv|format_number(1) }}%</td></tr>
  </tbody>
</table>
{% endmacro %}


{#- Performance Grade Component -#}
{% macro performance_grade(current_value, budget, label='Performance') %}
{% set ratio = current_value / budget if budget > 0 else 1 %}
{% set grade = 'A' if ratio < 0.6 else ('B' if ratio < 0.8 else ('C' if ratio < 1.0 else ('D' if ratio < 1.2 else 'F'))) %}
{% set grade_class = 'grade-a' if grade == 'A' else ('grade-b' if grade == 'B' else ('grade-c' if grade == 'C' else ('grade-d' if grade == 'D' else 'grade-f'))) %}
<div class="grade-card {{ grade_class }}">
  <div class="grade-letter">{{ grade }}</div>
  <div class="grade-label">{{ label }}</div>
  <div class="grade-detail">{{ current_value|int }} / {{ budget|int }}</div>
</div>
{% endmacro %}


{#- Budget Bar Component -#}
{% macro budget_bar(label, current, budget) %}
{% set pct = (current / budget * 100) if budget > 0 else 0 %}
{% set bar_class = 'ok' if pct < 80 else ('warn' if pct < 100 else 'danger') %}
<div class="budget-bar-container">
  <div class="budget-bar-header">
    <span class="budget-bar-label">{{ label }}</span>
    <span class="budget-bar-values">{{ current|int }} / {{ budget|int }}</span>
  </div>
  <div class="budget-bar">
    <div class="budget-bar-fill budget-bar-fill--{{ bar_class }}" style="width: {{ [pct, 100]|min }}%"></div>
  </div>
</div>
{% endmacro %}


{#- Hotspot Counter Component -#}
{% macro hotspot_counter(high_count, low_count, total) %}
<div class="hotspot-counter">
  <div class="hotspot-item hotspot-item--danger">
    <span class="hotspot-count">{{ high_count }}</span>
    <span class="hotspot-label">Hotspots</span>
  </div>
  <div class="hotspot-item hotspot-item--ok">
    <span class="hotspot-count">{{ low_count }}</span>
    <span class="hotspot-label">Optimized</span>
  </div>
  <div class="hotspot-item">
    <span class="hotspot-count">{{ total }}</span>
    <span class="hotspot-label">Total</span>
  </div>
</div>
{% endmacro %}


{#- Chart Explanation Component -#}
{% macro chart_explanation(explanations, chart_id) %}
{% if explanations %}
  {% set start_marker = '<div data-chart="' ~ chart_id ~ '">' %}
  {% set end_marker = '</div>' %}
  {% set start_pos = explanations.find(start_marker) %}
  {% if start_pos >= 0 %}
    {% set content_start = start_pos + start_marker|length %}
    {% set content_end = explanations.find(end_marker, content_start) %}
    {% if content_end >= 0 %}
      <div class="chart-explanation">{{ explanations[content_start:content_end]|safe }}</div>
    {% endif %}
  {% endif %}
{% endif %}
{% endmacro %}


{#- Callout Component -#}
{% macro callout(title, variant='default') %}
<div class="callout callout--{{ variant }}">
  <div class="callout-title">{{ title }}</div>
  <div class="callout-content">
    {{ caller() }}
  </div>
</div>
{% endmacro %}
