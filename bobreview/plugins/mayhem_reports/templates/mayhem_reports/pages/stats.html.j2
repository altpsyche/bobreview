{% extends "mayhem_reports/pages/base.html.j2" %}
{% from "components/macros.html.j2" import metric_table, stats_item %}

{% block title %}{{ config.title }} - {{ labels.get('stats', 'Statistics') }}{% endblock %}

{% block content %}
<!-- Statistical Summary -->
<section class="panel">
  <h2>{{ labels.get('statistical_summary', 'Performance Details') }}</h2>
  
  {% if llm.stats_interpretation %}
  <div class="llm-content">
    {{ llm.stats_interpretation|sanitize }}
  </div>
  {% endif %}
</section>

<!-- Draw Calls Complete Statistics -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('draw_calls', 'Draw Calls') }} {{ labels.get('complete_stats', 'Complete Statistics') }}</h2>
  {{ metric_table(labels.get('draw_calls', 'Draw Calls'), stats.draws, labels) }}
</section>

<!-- Triangles Complete Statistics -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('triangles', 'Triangles') }} {{ labels.get('complete_stats', 'Complete Statistics') }}</h2>
  {{ metric_table(labels.get('triangles', 'Triangles'), stats.tris, labels) }}
</section>

<!-- Performance Spikes (Outliers) -->
{% if stats.outliers %}
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('outlier_analysis', 'Performance Spikes') }}</h2>
  <p class="body-text">
    These frames show unusual performance that differs significantly from the typical load:
  </p>
  
  <div class="stats-grid">
    {{ stats_item(labels.get('outliers_detected', 'Spikes Detected'), stats.outliers|length) }}
    {{ stats_item(labels.get('detection_method', 'Sensitivity'), 'High (σ=' ~ config.thresholds.outlier_sigma ~ ')') }}
  </div>
  
  <table style="margin-top: 16px;">
    <thead>
      <tr>
        <th>{{ labels.get('index', 'Frame') }}</th>
        <th>{{ labels.get('testcase', 'Scene') }}</th>
        <th>{{ labels.get('draw_calls', 'Draw Calls') }}</th>
        <th>{{ labels.get('triangles', 'Triangles') }}</th>
        <th>{{ labels.get('severity', 'Severity') }}</th>
      </tr>
    </thead>
    <tbody>
      {% for outlier in stats.outliers[:15] %}
      <tr>
        <td>{{ outlier.index }}</td>
        <td>{{ outlier.testcase }}</td>
        <td>{{ outlier.draws }}</td>
        <td>{{ outlier.tris|format_number }}</td>
        <td>
          {% if outlier.zscore is defined %}
            {% if outlier.zscore > 3 %}
            <span style="color: var(--danger);">🔴 Critical</span>
            {% elif outlier.zscore > 2.5 %}
            <span style="color: var(--warn);">🟠 High</span>
            {% else %}
            <span style="color: var(--accent);">🟡 Moderate</span>
            {% endif %}
          {% else %}—{% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

<!-- Expected Performance Range -->
{% if stats.draws.ci_lower is defined and stats.draws.ci_upper is defined %}
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('confidence_intervals', 'Expected Performance Range') }}</h2>
  <p class="body-text">Based on your data, most frames should fall within these ranges:</p>
  
  <div class="stats-grid">
    {{ stats_item(labels.get('draw_calls', 'Draw Calls') ~ ' typical range', (stats.draws.ci_lower|format_number(0)) ~ ' – ' ~ (stats.draws.ci_upper|format_number(0))) }}
    {{ stats_item(labels.get('triangles', 'Triangles') ~ ' typical range', (stats.tris.ci_lower|default(0)|format_number(0)) ~ ' – ' ~ (stats.tris.ci_upper|default(0)|format_number(0))) }}
  </div>
</section>
{% endif %}

<!-- Full Data Table -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('full_sample_table', 'All Captured Frames') }}</h2>
  <p class="body-text">Complete list of all captured frames:</p>
  
  <table>
    <thead>
      <tr>
        <th>{{ labels.get('index', 'Index') }}</th>
        <th>{{ labels.get('testcase', 'Test Case') }}</th>
        <th>{{ labels.get('draw_calls', 'Draw Calls') }}</th>
        <th>{{ labels.get('triangles', 'Triangles') }}</th>
        <th>{{ labels.get('timestamp', 'Timestamp') }}</th>
        {% if has_images %}<th>{{ labels.get('screenshot', 'Screenshot') }}</th>{% endif %}
      </tr>
    </thead>
    <tbody>
      {% for point in data_points %}
      <tr>
        <td>{{ loop.index0 }}</td>
        <td>{{ point.testcase }}</td>
        <td>{{ point.draws }}</td>
        <td>{{ point.tris|format_number }}</td>
        <td>{{ point.ts }}</td>
        {% if has_images %}
        <td>
          {% if images[loop.index0] is defined and images[loop.index0] is not none %}
          <img src="{{ images[loop.index0].src }}" alt="{{ point.testcase }}" class="thumb-small" loading="lazy" />
          {% else %}-{% endif %}
        </td>
        {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endblock %}
