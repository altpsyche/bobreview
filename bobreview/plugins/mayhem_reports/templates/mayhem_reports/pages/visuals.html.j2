{% extends "mayhem_reports/pages/base.html.j2" %}
{% from "components/macros.html.j2" import chart_explanation, stats_item %}

{% block title %}{{ config.title }} - {{ labels.get('visuals', 'Visuals') }}{% endblock %}

{% block head_scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
{% endblock %}

{% block content %}
{# Build context for stats display #}
{% set draws_range = stats.draws.max - stats.draws.min %}
{% set tris_range = stats.tris.max - stats.tris.min %}

<!-- Visual Analysis Overview -->
<section class="panel">
  <h2>{{ labels.get('visual_analysis', 'Visual Analysis') }}</h2>
  <p class="body-text">
    These charts show how performance varies across your captured frames. Look for clusters, spikes, and patterns that indicate optimization opportunities.
  </p>
  
  {% if llm.visual_analysis %}
  <div class="llm-content">
    {{ llm.visual_analysis|sanitize }}
  </div>
  {% endif %}
  
  <div class="stats-grid" style="margin-top: 16px;">
    <div class="stats-item">
      <div class="stats-item-label">Draw Calls Range</div>
      <div class="stats-item-value">{{ stats.draws.min }} - {{ stats.draws.max }}</div>
    </div>
    <div class="stats-item">
      <div class="stats-item-label">Triangles Range</div>
      <div class="stats-item-value">{{ stats.tris.min|format_number }} - {{ stats.tris.max|format_number }}</div>
    </div>
  </div>
</section>

<!-- Draw Calls Timeline -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('draw_calls', 'Draw Calls') }} Timeline</h2>
  <p class="body-text">
    Timeline showing how draw calls vary across captures. Color-coded by performance zone.
  </p>
  
  <div class="chart-container">
    <div class="chart-description" style="font-size: 0.85rem; color: var(--text-soft); margin-bottom: 8px;">
      Key benchmarks: 
      <span style="color: var(--accent);">Typical</span> at {{ stats.draws.median|format_number(0) }}, 
      <span style="color: var(--warn);">Heavy Load</span> at {{ stats.draws.p90|format_number(0) }}, 
      <span style="color: var(--danger);">Very Heavy</span> at {{ stats.draws.p95|format_number(0) }}.
    </div>
    <canvas id="draws_timeline"></canvas>
    {% if llm.chart_explanations %}
    {{ chart_explanation(llm.chart_explanations, 'draws_timeline') }}
    {% endif %}
  </div>
  
  <div class="stats-grid" style="margin-top: 16px;">
    {{ stats_item('Light Load (25%)', stats.draws.q1|format_number(0)) }}
    {{ stats_item('Typical Load', stats.draws.median|format_number(0)) }}
    {{ stats_item('Heavy Load (75%)', stats.draws.q3|format_number(0)) }}
    {{ stats_item('Typical Spread', stats.draws.stdev|format_number(1)) }}
  </div>
</section>

<!-- Triangles Timeline -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('triangles', 'Triangles') }} Timeline</h2>
  <p class="body-text">
    Timeline showing how triangles vary across captures. This reveals patterns in your data.
  </p>
  
  <div class="chart-container">
    <div class="chart-description" style="font-size: 0.85rem; color: var(--text-soft); margin-bottom: 8px;">
      Key benchmarks: 
      <span style="color: var(--accent);">Typical</span> at {{ stats.tris.median|format_number(0) }}, 
      <span style="color: var(--warn);">Heavy Load</span> at {{ stats.tris.p90|format_number(0) }}, 
      <span style="color: var(--danger);">Very Heavy</span> at {{ stats.tris.p95|format_number(0) }}.
    </div>
    <canvas id="tris_timeline"></canvas>
    {% if llm.chart_explanations %}
    {{ chart_explanation(llm.chart_explanations, 'tris_timeline') }}
    {% endif %}
  </div>
  
  <div class="stats-grid" style="margin-top: 16px;">
    {{ stats_item('Light Load (25%)', stats.tris.q1|format_number(0)) }}
    {{ stats_item('Typical Load', stats.tris.median|format_number(0)) }}
    {{ stats_item('Heavy Load (75%)', stats.tris.q3|format_number(0)) }}
    {{ stats_item('Typical Spread', stats.tris.stdev|format_number(0)) }}
  </div>
</section>

<!-- Scatter Plot: Draw Calls vs Triangles -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('draw_calls', 'Draw Calls') }} vs {{ labels.get('triangles', 'Triangles') }}</h2>
  <p class="body-text">
    Scatter plot showing the relationship between draw calls and triangles. Points are color-coded by performance zone.
  </p>
  
  <div class="chart-container">
    <canvas id="scatter"></canvas>
    {% if llm.chart_explanations %}
    {{ chart_explanation(llm.chart_explanations, 'scatter') }}
    {% endif %}
  </div>
</section>
{% endblock %}

{% block scripts %}
{% if charts %}
<script>
{% if charts.draws_timeline %}{{ charts.draws_timeline|safe }}{% endif %}
{% if charts.tris_timeline %}{{ charts.tris_timeline|safe }}{% endif %}
{% if charts.scatter %}{{ charts.scatter|safe }}{% endif %}
</script>
{% endif %}
{% endblock %}
