{
    "schema_version": "1.0",
    "id": "hello_world",
    "name": "Hello World Report",
    "version": "1.0.0",
    "description": "Example report system for the Hello World plugin",
    "author": "BobReview Team",
    "data_source": {
        "type": "hello_csv",
        "input_format": "csv",
        "fields": {
            "name": {
                "type": "string",
                "required": true
            },
            "score": {
                "type": "float",
                "required": true,
                "min": 0,
                "max": 100
            },
            "timestamp": {
                "type": "integer",
                "required": false
            }
        },
        "validation": {
            "skip_invalid": true,
            "strict_mode": false
        }
    },
    "extensions": {
        "metrics": {
            "primary": [
                "score"
            ],
            "timestamp_field": "timestamp"
        }
    },
    "llm_generators": [
        {
            "id": "summary",
            "name": "Executive Summary",
            "description": "Generate an executive summary of the scores",
            "prompt_template": "Analyze the following score data and provide a brief executive summary.\n\nData:\n{{data_table}}\n\nStatistics:\n- Average Score: {{stats.score_mean}}\n- Highest: {{stats.score_max}}\n- Lowest: {{stats.score_min}}\n\nProvide a 2-3 sentence summary highlighting key findings.",
            "returns": "string",
            "enabled": true
        },
        {
            "id": "recommendations",
            "name": "Recommendations",
            "description": "Generate improvement recommendations",
            "prompt_template": "Based on the score data below, suggest 3-5 actionable recommendations for improvement.\n\nData:\n{{data_table}}\n\nFocus on entries with scores below 70.",
            "returns": "string",
            "enabled": true
        }
    ],
    "theme": {
        "preset": "hello_cyberpunk"
    },
    "pages": [
        {
            "id": "home",
            "filename": "index.html",
            "nav_label": "Overview",
            "nav_order": 1,
            "template": {
                "type": "jinja2",
                "name": "hello_world/pages/home.html.j2"
            },
            "llm_mappings": {
                "summary": "summary"
            },
            "charts": [
                {
                    "id": "score_bar",
                    "type": "bar",
                    "title": "Score Comparison",
                    "x_field": "name",
                    "y_field": "score"
                },
                {
                    "id": "distribution",
                    "type": "doughnut",
                    "title": "Score Distribution",
                    "x_field": "category",
                    "y_field": "count"
                }
            ],
            "enabled": true
        },
        {
            "id": "rankings",
            "filename": "rankings.html",
            "nav_label": "Rankings",
            "nav_order": 2,
            "template": {
                "type": "jinja2",
                "name": "hello_world/pages/rankings.html.j2"
            },
            "llm_mappings": {
                "recommendations": "recommendations"
            },
            "charts": [
                {
                    "id": "timeline",
                    "type": "line",
                    "title": "Score Timeline",
                    "x_field": "timestamp",
                    "y_field": "score"
                }
            ],
            "enabled": true
        }
    ],
    "labels": {
        "report_title": "Hello World Report",
        "score_label": "Score",
        "name_label": "Name",
        "excellent": "Excellent",
        "good": "Good",
        "needs_improvement": "Needs Improvement"
    },
    "output": {
        "default_filename": "hello_report.html",
        "embed_images": true
    }
}