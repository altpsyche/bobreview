{% extends "hello_world/pages/base.html.j2" %}

{% block content %}
<header>
    <h1>🎉 {{ config.title | default('Hello World Report') }}</h1>
    <p class="meta">{{ meta_text }}</p>
</header>

<!-- Statistics Overview -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="value">{{ data_points | length }}</div>
        <div class="label">Total Entries</div>
    </div>
    <div class="stat-card">
        <div class="value">{{ "%.1f" | format(stats.score_mean | default(0)) }}</div>
        <div class="label">Average Score</div>
    </div>
    <div class="stat-card">
        <div class="value">{{ stats.score_max | default(0) | int }}</div>
        <div class="label">Highest Score</div>
    </div>
    <div class="stat-card">
        <div class="value">{{ category_counts.excellent | default(0) }}</div>
        <div class="label">🌟 Excellent</div>
    </div>
</div>

<!-- LLM Summary -->
{% if llm.summary %}
<div class="card">
    <h2>📊 Executive Summary</h2>
    <div class="llm-content">
        {{ llm.summary | safe }}
    </div>
</div>
{% endif %}

<!-- Charts -->
<div class="card">
    <h2>📈 Score Comparison</h2>
    <div class="chart-container">
        <canvas id="scoreBarChart"></canvas>
    </div>
</div>

<div class="card">
    <h2>🍩 Score Distribution</h2>
    <div class="chart-container">
        <canvas id="distributionChart"></canvas>
    </div>
</div>

<!-- Top Performers -->
<div class="card">
    <h2>🏆 Top Performers</h2>
    <table>
        <thead>
            <tr>
                <th>Rank</th>
                <th>{{ labels.name_label | default('Name') }}</th>
                <th>{{ labels.score_label | default('Score') }}</th>
                <th>Category</th>
            </tr>
        </thead>
        <tbody>
            {% for item in ranked_data[:5] %}
            <tr>
                <td>{{ loop.index }}</td>
                <td>{{ item.name }}</td>
                <td class="{% if item.score >= 90 %}score-excellent{% elif item.score >= 70 %}score-good{% else %}score-low{% endif %}">
                    {{ item.score | int }}
                </td>
                <td>
                    {% if item.score >= 90 %}🌟 {{ labels.excellent | default('Excellent') }}
                    {% elif item.score >= 70 %}👍 {{ labels.good | default('Good') }}
                    {% else %}⚠️ {{ labels.needs_improvement | default('Needs Work') }}{% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

{% block scripts %}
<script>
// Score Bar Chart
{% if charts.score_bar %}
const barCtx = document.getElementById('scoreBarChart').getContext('2d');
new Chart(barCtx, {{ charts.score_bar | safe }});
{% endif %}

// Distribution Doughnut Chart
{% if charts.distribution %}
const doughnutCtx = document.getElementById('distributionChart').getContext('2d');
new Chart(doughnutCtx, {{ charts.distribution | safe }});
{% endif %}
</script>
{% endblock %}
