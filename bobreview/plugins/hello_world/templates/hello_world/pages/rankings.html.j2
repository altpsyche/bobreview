{% extends "hello_world/pages/base.html.j2" %}

{% block content %}
<header>
    <h1>📋 Rankings</h1>
    <p class="meta">Complete list sorted by score</p>
</header>

<!-- Timeline Chart -->
<div class="card">
    <h2>📈 Score Timeline</h2>
    <div class="chart-container">
        <canvas id="timelineChart"></canvas>
    </div>
</div>

<!-- LLM Recommendations -->
{% if llm.recommendations %}
<div class="card">
    <h2>💡 Recommendations</h2>
    <div class="llm-content">
        {{ llm.recommendations | safe }}
    </div>
</div>
{% endif %}

<!-- Category Breakdown -->
<div class="stats-grid">
    <div class="stat-card" style="background: var(--ok-soft);">
        <div class="value score-excellent">{{ category_counts.excellent | default(0) }}</div>
        <div class="label">🌟 Excellent (90+)</div>
    </div>
    <div class="stat-card" style="background: var(--warn-soft);">
        <div class="value score-good">{{ category_counts.good | default(0) }}</div>
        <div class="label">👍 Good (70-89)</div>
    </div>
    <div class="stat-card" style="background: var(--danger-soft);">
        <div class="value score-low">{{ category_counts.needs_improvement | default(0) }}</div>
        <div class="label">⚠️ Needs Work (<70)</div>
    </div>
</div>

<!-- Full Rankings Table -->
<div class="card">
    <h2>🏆 Complete Rankings</h2>
    <table>
        <thead>
            <tr>
                <th>Rank</th>
                <th>{{ labels.name_label | default('Name') }}</th>
                <th>{{ labels.score_label | default('Score') }}</th>
                <th>Category</th>
                <th>Source File</th>
            </tr>
        </thead>
        <tbody>
            {% for item in ranked_data %}
            <tr>
                <td>
                    {% if loop.index == 1 %}🥇{% elif loop.index == 2 %}🥈{% elif loop.index == 3 %}🥉{% else %}{{ loop.index }}{% endif %}
                </td>
                <td><strong>{{ item.name }}</strong></td>
                <td class="{% if item.score >= 90 %}score-excellent{% elif item.score >= 70 %}score-good{% else %}score-low{% endif %}">
                    {{ item.score | int }}
                </td>
                <td>
                    {% if item.score >= 90 %}🌟 {{ labels.excellent | default('Excellent') }}
                    {% elif item.score >= 70 %}👍 {{ labels.good | default('Good') }}
                    {% else %}⚠️ {{ labels.needs_improvement | default('Needs Work') }}{% endif %}
                </td>
                <td style="color: var(--text-soft); font-size: 0.85rem;">{{ item.source | default('-') }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<!-- Score Range Info -->
{% if score_range %}
<div class="card">
    <h2>📐 Score Analysis</h2>
    <div class="stats-grid">
        <div class="stat-card">
            <div class="value score-excellent">{{ score_range.max | int }}</div>
            <div class="label">Highest Score</div>
        </div>
        <div class="stat-card">
            <div class="value score-low">{{ score_range.min | int }}</div>
            <div class="label">Lowest Score</div>
        </div>
        <div class="stat-card">
            <div class="value">{{ score_range.spread | int }}</div>
            <div class="label">Score Spread</div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block scripts %}
<script>
// Timeline Chart
{% if charts.timeline %}
const timelineCtx = document.getElementById('timelineChart').getContext('2d');
new Chart(timelineCtx, {{ charts.timeline | safe }});
{% endif %}
</script>
{% endblock %}
