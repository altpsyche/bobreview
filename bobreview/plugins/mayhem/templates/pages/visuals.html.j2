{% extends "base.html.j2" %}
{% from "components/macros.html.j2" import chart_explanation %}
{% from "components/macros.html.j2" import stat_card, stats_item %}

{% block title %}{{ config.title }} - {{ labels.get('visual_analysis', 'Visual Analysis') }}{% endblock %}

{% block head_scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"></script>
{% endblock %}

{% block content %}
{# Build context for interpolation #}
{% set draws_range = stats.draws.max - stats.draws.min %}
{% set tris_range = stats.tris.max - stats.tris.min %}

{% set ctx = {
  'stats': stats,
  'draws_range': draws_range,
  'tris_range': tris_range|format_number
} %}

<section class="panel">
  <h2>{{ labels.get('visual_analysis', 'Visual Analysis') }}</h2>
  <p class="body-text">
    {{ content.visual_analysis_intro|default('These charts show how performance varies across your captured frames. Look for clusters, spikes, and patterns that indicate optimization opportunities.') }}
  </p>
  
  {{ llm.visual_analysis|sanitize }}
  
  <div class="summary-grid" style="margin-top: 16px;">
    {# Data-driven distribution cards #}
    {% if content.stat_distribution_cards %}
    {% for card in content.stat_distribution_cards %}
    <div class="stat-card">
      <div class="stat-label">{{ card.label }}</div>
      <div class="stat-value">{{ card.value|interpolate(ctx) }}</div>
      <div class="stat-sub">{{ card.sub|interpolate(ctx) }}</div>
    </div>
    {% endfor %}
    {% else %}
    {# Fallback #}
    <div class="stat-card">
      <div class="stat-label">Draw Calls Distribution</div>
      <div class="stat-value">{{ stats.draws.min }} - {{ stats.draws.max }}</div>
      <div class="stat-sub">Range of {{ draws_range }} draw calls</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Triangles Distribution</div>
      <div class="stat-value">{{ stats.tris.min|format_number }} - {{ stats.tris.max|format_number }}</div>
      <div class="stat-sub">Range of {{ tris_range|format_number }} triangles</div>
    </div>
    {% endif %}
  </div>
</section>

<!-- Draw Calls Timeline -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('draw_calls', 'Draw Calls') }} {{ labels.get('timeline', 'Timeline') }}</h2>
  <p class="body-text">
    {{ content.primary_timeline_intro|default('Timeline showing how draw calls vary across captures. Color-coded by performance zone.')|safe }}
  </p>
  
  <div class="chart-container">
    <div class="chart-description">
      {{ labels.get('key_benchmarks', 'Key benchmarks') }}: 
      <span style="color: var(--accent);">{{ labels.get('q2_label', 'Typical') }}</span> at {{ stats.draws.median|format_number(0) }}, 
      <span style="color: var(--warn);">{{ labels.get('p90', 'Heavy Load') }}</span> at {{ stats.draws.p90|format_number(0) }}, 
      <span style="color: var(--danger);">{{ labels.get('p95', 'Very Heavy') }}</span> at {{ stats.draws.p95|format_number(0) }}.
    </div>
    <canvas id="draws_timeline"></canvas>
    {% if llm_content and llm_content.get('chart_explanations') %}
    {{ chart_explanation(llm_content.get('chart_explanations'), 'draws_timeline') }}
    {% endif %}
  </div>
  
  <div class="stats-grid" style="margin-top: 16px;">
    {# Data-driven percentile stats #}
    {% if content.percentile_stats %}
    {% for item in content.percentile_stats %}
    <div class="stats-item">
      <div class="stats-item-label">{{ item.label }}</div>
      <div class="stats-item-value">{{ stats.draws[item.key]|format_number(0) }}</div>
    </div>
    {% endfor %}
    {% else %}
    {{ stats_item('Light Load (25%)', stats.draws.q1|format_number(0)) }}
    {{ stats_item('Typical Load', stats.draws.median|format_number(0)) }}
    {{ stats_item('Heavy Load (75%)', stats.draws.q3|format_number(0)) }}
    {{ stats_item('Typical Spread', stats.draws.stdev|format_number(1)) }}
    {% endif %}
  </div>
</section>

<!-- Triangles Timeline -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('triangles', 'Triangles') }} {{ labels.get('timeline', 'Timeline') }}</h2>
  <p class="body-text">
    {{ content.secondary_timeline_intro|default('Timeline showing how triangles vary across captures. This reveals patterns in your data.')|safe }}
  </p>
  
  <div class="chart-container">
    <div class="chart-description">
      {{ labels.get('key_benchmarks', 'Key benchmarks') }}: 
      <span style="color: var(--accent);">{{ labels.get('q2_label', 'Typical') }}</span> at {{ stats.tris.median|format_number(0) }}, 
      <span style="color: var(--warn);">{{ labels.get('p90', 'Heavy Load') }}</span> at {{ stats.tris.p90|format_number(0) }}, 
      <span style="color: var(--danger);">{{ labels.get('p95', 'Very Heavy') }}</span> at {{ stats.tris.p95|format_number(0) }}.
    </div>
    <canvas id="tris_timeline"></canvas>
    {% if llm_content and llm_content.get('chart_explanations') %}
    {{ chart_explanation(llm_content.get('chart_explanations'), 'tris_timeline') }}
    {% endif %}
  </div>
  
  <div class="stats-grid" style="margin-top: 16px;">
    {% if content.percentile_stats %}
    {% for item in content.percentile_stats %}
    <div class="stats-item">
      <div class="stats-item-label">{{ item.label }}</div>
      <div class="stats-item-value">{{ stats.tris[item.key]|format_number(0) }}</div>
    </div>
    {% endfor %}
    {% else %}
    {{ stats_item('Light Load (25%)', stats.tris.q1|format_number(0)) }}
    {{ stats_item('Typical Load', stats.tris.median|format_number(0)) }}
    {{ stats_item('Heavy Load (75%)', stats.tris.q3|format_number(0)) }}
    {{ stats_item('Typical Spread', stats.tris.stdev|format_number(0)) }}
    {% endif %}
  </div>
</section>

<!-- Scatter Plot -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('draw_calls', 'Draw Calls') }} vs {{ labels.get('triangles', 'Triangles') }}</h2>
  <p class="body-text">
    {{ content.scatter_plot_intro|default('Scatter plot showing the relationship between draw calls and triangles. Points are color-coded by performance zone.')|safe }}
  </p>
  
  <div class="chart-container">
    <canvas id="scatter"></canvas>
    {% if llm_content and llm_content.get('chart_explanations') %}
    {{ chart_explanation(llm_content.get('chart_explanations'), 'scatter') }}
    {% endif %}
  </div>
</section>
{% endblock %}

{% block scripts %}
{% if charts %}
<script>
{{ charts.draws_timeline|safe }}
{{ charts.tris_timeline|safe }}
{{ charts.scatter|safe }}
</script>
{% endif %}
{% endblock %}

