{% extends "base.html.j2" %}
{% from "components/macros.html.j2" import metric_table, stats_item %}

{% block title %}{{ config.title }} - {{ labels.get('statistical_summary', 'Statistical Summary') }}{% endblock %}

{% block content %}
<section class="panel">
  <h2>{{ labels.get('statistical_summary', 'Statistical Summary') }}</h2>
  
  {{ llm.stats_interpretation|sanitize }}
</section>

<!-- Complete Statistics -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('draw_calls', 'Draw Calls') }} {{ labels.get('complete_stats', 'Complete Statistics') }}</h2>
  {{ metric_table(labels.get('draw_calls', 'Draw Calls'), stats.draws, labels) }}
</section>

<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('triangles', 'Triangles') }} {{ labels.get('complete_stats', 'Complete Statistics') }}</h2>
  {{ metric_table(labels.get('triangles', 'Triangles'), stats.tris, labels) }}
</section>

<!-- Outlier Analysis -->
{% if stats.outliers %}
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('outlier_analysis', 'Outlier Analysis') }}</h2>
  <p class="body-text">{{ content.outlier_desc|default('Data points significantly deviating from the mean:') }}</p>
  
  <div class="stats-grid">
    {{ stats_item(labels.get('outliers_detected', 'Outliers Detected'), stats.outliers|length) }}
    {{ stats_item(labels.get('detection_method', 'Detection Method'), 'Z-Score (σ=' ~ config.thresholds.outlier_sigma ~ ')') }}
  </div>
  
  <table style="margin-top: 16px;">
    <thead>
      <tr>
        <th>{{ labels.get('index', 'Index') }}</th>
        <th>{{ labels.get('testcase', 'Test Case') }}</th>
        <th>{{ labels.get('draw_calls', 'Draw Calls') }}</th>
        <th>{{ labels.get('triangles', 'Triangles') }}</th>
        <th>{{ labels.get('zscore', 'Z-Score') }}</th>
      </tr>
    </thead>
    <tbody>
      {% for outlier in stats.outliers[:15] %}
      <tr>
        <td>{{ outlier.index }}</td>
        <td>{{ outlier.testcase }}</td>
        <td>{{ outlier.draws }}</td>
        <td>{{ outlier.tris|format_number }}</td>
        <td>{{ outlier.zscore|format_number(2) if outlier.zscore else 'N/A' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

<!-- Confidence Intervals -->
{% if stats.draws.ci_lower is defined and stats.draws.ci_upper is defined %}
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('confidence_intervals', 'Confidence Intervals') }}</h2>
  
  <div class="stats-grid">
    {{ stats_item(labels.get('draw_calls', 'Draw Calls') ~ ' 95% CI', (stats.draws.ci_lower|format_number(1)) ~ ' - ' ~ (stats.draws.ci_upper|format_number(1))) }}
    {{ stats_item(labels.get('triangles', 'Triangles') ~ ' 95% CI', (stats.tris.ci_lower|default(0)|format_number(0)) ~ ' - ' ~ (stats.tris.ci_upper|default(0)|format_number(0))) }}
  </div>
</section>
{% endif %}

<!-- Full Data Table -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('full_sample_table', 'Full Sample Table') }}</h2>
  <p class="body-text">{{ content.all_captures|default('All captured data points:') }}</p>
  
  <table>
    <thead>
      <tr>
        <th>{{ labels.get('index', 'Index') }}</th>
        <th>{{ labels.get('testcase', 'Test Case') }}</th>
        <th>{{ labels.get('draw_calls', 'Draw Calls') }}</th>
        <th>{{ labels.get('triangles', 'Triangles') }}</th>
        <th>{{ labels.get('timestamp', 'Timestamp') }}</th>
        {% if has_images %}
        <th>{{ labels.get('screenshot', 'Screenshot') }}</th>
        {% endif %}
      </tr>
    </thead>
    <tbody>
      {% for point in data_points %}
      <tr>
        <td>{{ loop.index0 }}</td>
        <td>{{ point.testcase }}</td>
        <td>{{ point.draws }}</td>
        <td>{{ point.tris|format_number }}</td>
        <td>{{ point.ts }}</td>
        {% if has_images %}
        <td>
          {% if images[loop.index0] is defined %}
          <img src="{{ images[loop.index0].src }}" alt="{{ point.testcase }}" class="thumb-small" loading="lazy" />
          {% else %}-{% endif %}
        </td>
        {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endblock %}

