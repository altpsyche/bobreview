{% extends "base.html.j2" %}
{% from "components/macros.html.j2" import stat_card, stats_item %}

{% block title %}{{ config.title }} - {{ labels.optimization }}{% endblock %}

{% block content %}
{# Use namespace for counters to work across loop scopes #}
{% set ns = namespace(
  high_geometry_count=0,
  high_draw_count=0,
  over_hard_cap=0,
  priority_critical=0,
  priority_high=0,
  priority_medium=0,
  within_budget=0
) %}

{# Calculate hotspot counts #}
{% for frame in stats.high_load %}
  {% set data = frame[1] %}
  {% if data.tris >= config.thresholds.high_load_tri_threshold %}
    {% set ns.high_geometry_count = ns.high_geometry_count + 1 %}
  {% endif %}
  {% if data.draws >= config.thresholds.high_load_draw_threshold %}
    {% set ns.high_draw_count = ns.high_draw_count + 1 %}
  {% endif %}
{% endfor %}

{# Count frames exceeding caps #}
{% for p in data_points %}
  {% if p.draws > config.thresholds.draw_hard_cap or p.tris > config.thresholds.tri_hard_cap %}
    {% set ns.over_hard_cap = ns.over_hard_cap + 1 %}
  {% endif %}
  {% if p.draws > config.thresholds.draw_hard_cap * 1.2 or p.tris > config.thresholds.tri_hard_cap * 1.2 %}
    {% set ns.priority_critical = ns.priority_critical + 1 %}
  {% elif (p.draws > config.thresholds.draw_hard_cap and p.draws <= config.thresholds.draw_hard_cap * 1.2) or (p.tris > config.thresholds.tri_hard_cap and p.tris <= config.thresholds.tri_hard_cap * 1.2) %}
    {% set ns.priority_high = ns.priority_high + 1 %}
  {% elif (p.draws > config.thresholds.draw_soft_cap and p.draws <= config.thresholds.draw_hard_cap) or (p.tris > config.thresholds.tri_soft_cap and p.tris <= config.thresholds.tri_hard_cap) %}
    {% set ns.priority_medium = ns.priority_medium + 1 %}
  {% elif p.draws <= config.thresholds.draw_soft_cap and p.tris <= config.thresholds.tri_soft_cap %}
    {% set ns.within_budget = ns.within_budget + 1 %}
  {% endif %}
{% endfor %}

<!-- Performance Budgets -->
<section class="panel">
  <h2>{{ labels.get('performance_budgets', 'Performance Budgets') }}</h2>
  <p class="body-text">
    {{ content.performance_budgets_intro|default('Establish and maintain performance budgets to ensure consistent frame rates and responsive gameplay. Any capture exceeding the hard cap should be treated as a performance issue.') }}
  </p>
  
  <div class="summary-grid">
    {# Data-driven stat cards from JSON - uses |interpolate(config) to substitute {key} placeholders #}
    {% if content.budget_cards %}
    {% for card in content.budget_cards %}
    <div class="stat-card {{ card.variant|default('ok') }}">
      <div class="stat-label">{{ card.label }}</div>
      <div class="stat-value">{{ card.value|interpolate(config) }}</div>
      <div class="stat-sub">{{ card.sub|interpolate(config) }}</div>
    </div>
    {% endfor %}
    {% else %}
    {# Fallback if no budget_cards defined in JSON #}
    <div class="stat-card ok">
      <div class="stat-label">Draw Calls Budget</div>
      <div class="stat-value">&le; {{ config.thresholds.draw_soft_cap }}</div>
      <div class="stat-sub">Soft cap {{ config.thresholds.draw_soft_cap }} &middot; hard cap {{ config.thresholds.draw_hard_cap }}</div>
    </div>
    <div class="stat-card ok">
      <div class="stat-label">Triangles Budget</div>
      <div class="stat-value">&le; {{ (config.thresholds.tri_soft_cap / 1000)|format_number(0) }}k</div>
      <div class="stat-sub">Soft cap {{ config.thresholds.tri_soft_cap|format_number(0) }} &middot; hard cap {{ config.thresholds.tri_hard_cap|format_number(0) }}</div>
    </div>
    {% endif %}
    
    {# Status card always shown #}
    <div class="stat-card {% if ns.over_hard_cap > 0 %}danger{% else %}ok{% endif %}">
      <div class="stat-label">{{ labels.get('current_status', 'Current Status') }}</div>
      <div class="stat-value">{{ ns.over_hard_cap }}</div>
      <div class="stat-sub">{{ labels.get('frames_exceeding_caps', 'Frames exceeding hard caps') }}</div>
    </div>
  </div>
  
  <div class="callout warn" style="margin-top: 16px;">
    <div class="callout-title">{{ labels.budget_guidelines }}</div>
    <ul class="body-text">
      {% if content.budget_guidelines %}
      {% for item in content.budget_guidelines %}
      <li><strong>{{ item.title }}:</strong> {{ item.description }}</li>
      {% endfor %}
      {% else %}
      <li><strong>Soft Cap:</strong> Target performance level for most scenes. Aim to stay below this threshold.</li>
      <li><strong>Hard Cap:</strong> Maximum acceptable performance cost. Exceeding this requires immediate optimization.</li>
      <li><strong>Budget Tracking:</strong> Monitor budgets across all development stages to prevent performance regressions.</li>
      {% endif %}
    </ul>
  </div>
</section>

<!-- Critical Hotspot -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('critical_hotspot', 'Critical Hotspot') }} - {{ labels.index }} {{ critical.index }}</h2>
  <p class="body-text">
    {{ content.critical_hotspot_intro|default('The highest-priority optimization target. This frame has the worst performance characteristics and should be addressed first for maximum impact.') }}
  </p>
  
  <div class="callout critical">
    <div class="callout-title">{{ labels.index }} {{ critical.index }}{% if data_points[critical.index] is defined %} – {{ data_points[critical.index].img|default('') }}{% endif %}</div>
    <div><strong>{{ critical.draws }} {{ labels.draw_calls }}</strong> &middot; <strong>{{ critical.tris|format_number }} {{ labels.triangles }}</strong></div>
    <div style="margin-top: 8px; font-size: 12px;">
      {{ labels.exceeds_budget_by }}: {{ [0, critical.draws - config.thresholds.draw_hard_cap]|max }} {{ labels.draw_calls|lower }}
      {% if critical.tris > config.thresholds.tri_hard_cap %}
       | {{ labels.exceeds_budget_by }}: {{ (critical.tris - config.thresholds.tri_hard_cap)|format_number }} {{ labels.triangles|lower }}
      {% endif %}
    </div>
  </div>
  
  {% if images[critical.index] is defined %}
  <img
    class="thumb-large"
    src="{{ images[critical.index].src }}"
    alt="Critical hotspot frame (index {{ critical.index }})"
    style="max-width: 100%; margin-top: 12px;"
  />
  {% endif %}
  
  {{ llm.optimization|sanitize }}
  
  <div class="callout" style="margin-top: 12px;">
    <div class="callout-title">{{ labels.recommended_actions }}</div>
    <ul class="body-text">
      {% if content.critical_hotspot_actions %}
      {% for action in content.critical_hotspot_actions %}
      <li>{{ action }}</li>
      {% endfor %}
      {% else %}
      <li>Profile this specific frame to identify expensive draw calls</li>
      <li>Look for redundant or unnecessary rendering operations</li>
      <li>Consider LOD (Level of Detail) systems for distant objects</li>
      <li>Investigate potential for object culling or occlusion</li>
      <li>Batch similar materials and meshes where possible</li>
      {% endif %}
    </ul>
  </div>
</section>

<!-- High-Geometry Hotspots -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('high_geometry_hotspots', 'High-Geometry Hotspots') }}</h2>
  <p class="body-text">
    {{ labels.frames_with_excessive }} {{ labels.triangles|lower }} (≥ {{ config.thresholds.high_load_tri_threshold|format_number(0) }}).
    {{ labels.affects_frames }} <strong>{{ ns.high_geometry_count }} {{ labels.frame_count_suffix }}</strong>.
  </p>
  
  <div class="callout" style="margin-top: 12px;">
    <div class="callout-title">{{ labels.geometry_optimization }}</div>
    <ul class="body-text">
      {% if content.geometry_strategies %}
      {% for item in content.geometry_strategies %}
      <li><strong>{{ item.title }}:</strong> {{ item.description }}</li>
      {% endfor %}
      {% else %}
      <li><strong>LOD Systems:</strong> Implement multiple levels of detail for complex meshes</li>
      <li><strong>Mesh Simplification:</strong> Reduce polygon counts on distant or less important objects</li>
      <li><strong>Frustum Culling:</strong> Ensure objects outside the camera view are not rendered</li>
      <li><strong>Occlusion Culling:</strong> Skip rendering objects hidden behind other geometry</li>
      <li><strong>Instancing:</strong> Use GPU instancing for repeated geometry</li>
      {% endif %}
    </ul>
  </div>
</section>

<!-- High-Draw Hotspots -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('high_draw_hotspots', 'High-Draw Hotspots') }}</h2>
  <p class="body-text">
    {{ labels.frames_with_excessive }} {{ labels.draw_calls|lower }} (≥ {{ config.thresholds.high_load_draw_threshold }}).
    {{ labels.affects_frames }} <strong>{{ ns.high_draw_count }} {{ labels.frame_count_suffix }}</strong>.
  </p>
  
  <div class="callout" style="margin-top: 12px;">
    <div class="callout-title">{{ labels.drawcall_optimization }}</div>
    <ul class="body-text">
      {% if content.draw_call_strategies %}
      {% for item in content.draw_call_strategies %}
      <li><strong>{{ item.title }}:</strong> {{ item.description }}</li>
      {% endfor %}
      {% else %}
      <li><strong>Batching:</strong> Combine meshes with identical materials into single draw calls</li>
      <li><strong>Material Reduction:</strong> Minimize unique material instances and shader variants</li>
      <li><strong>Atlasing:</strong> Combine multiple textures into texture atlases</li>
      <li><strong>GPU Instancing:</strong> Render multiple copies of the same mesh in one call</li>
      <li><strong>Static Batching:</strong> Pre-combine static geometry at build time</li>
      <li><strong>Dynamic Batching:</strong> Combine small dynamic objects at runtime</li>
      {% endif %}
    </ul>
  </div>
</section>

<!-- System-Level Recommendations -->
{% if llm.recommendations %}
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('system_recommendations', 'System-Level Recommendations') }}</h2>
  <p class="body-text">
    {{ content.system_recommendations_intro|default('Strategic recommendations for improving overall performance architecture and workflow.') }}
  </p>
  {{ llm.recommendations|sanitize }}
</section>
{% endif %}

<!-- Optimization Priority Matrix -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('priority_matrix', 'Optimization Priority Matrix') }}</h2>
  <p class="body-text">
    {{ content.priority_matrix_intro|default('Prioritize optimization work based on impact and effort. Focus on high-impact, low-effort improvements first.') }}
  </p>
  
  <div class="stats-grid">
    <div class="stats-item" style="border-left: 3px solid var(--danger);">
      <div class="stats-item-label">{{ labels.priority_critical }}</div>
      <div class="stats-item-value">{{ ns.priority_critical }}</div>
    </div>
    
    <div class="stats-item" style="border-left: 3px solid var(--warn);">
      <div class="stats-item-label">{{ labels.priority_high }}</div>
      <div class="stats-item-value">{{ ns.priority_high }}</div>
    </div>
    
    <div class="stats-item" style="border-left: 3px solid var(--accent);">
      <div class="stats-item-label">{{ labels.priority_medium }}</div>
      <div class="stats-item-value">{{ ns.priority_medium }}</div>
    </div>
    
    <div class="stats-item" style="border-left: 3px solid var(--ok);">
      <div class="stats-item-label">{{ labels.within_budget }}</div>
      <div class="stats-item-value">{{ ns.within_budget }}</div>
    </div>
  </div>
</section>

{% endblock %}
