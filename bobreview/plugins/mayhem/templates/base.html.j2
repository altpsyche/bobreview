<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{% block title %}{{ config.title }}{% endblock %}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" integrity="sha512-z3gLpd7yknf1YoNbCzqRKc4qyor8gaKU1qmn+CShxbuBusANI9QpRohGBreCFkKxLhei6S9CQXFEbbKuqLg0DA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  {% block head_scripts %}{% endblock %}
  
  <style>
    /* Theme CSS Variables - plugin-defined, can override defaults */
    :root {
      /* Backgrounds */
      --bg: {{ theme.bg if theme else '#070b10' }};
      --bg-elevated: {{ theme.bg_elevated if theme else '#0e141b' }};
      --bg-soft: {{ theme.bg_soft if theme else '#151c26' }};
      
      /* Accents */
      --accent: {{ theme.accent if theme else '#4ea1ff' }};
      --accent-soft: {{ theme.accent_soft if theme else 'rgba(78, 161, 255, 0.15)' }};
      --accent-strong: {{ theme.accent_strong if theme else '#ffb347' }};
      
      /* Text */
      --text-main: {{ theme.text_main if theme else '#f5f7fb' }};
      --text-soft: {{ theme.text_soft if theme else '#a8b3c5' }};
      
      /* Status */
      --ok: {{ theme.ok if theme else '#4fd18b' }};
      --ok-soft: {{ theme.ok_soft if theme else 'rgba(79, 209, 139, 0.15)' }};
      --warn: {{ theme.warn if theme else '#e6b35c' }};
      --warn-soft: {{ theme.warn_soft if theme else 'rgba(230, 179, 92, 0.15)' }};
      --danger: {{ theme.danger if theme else '#ff5c5c' }};
      --danger-soft: {{ theme.danger_soft if theme else 'rgba(255, 92, 92, 0.15)' }};
      
      /* Border & Effects */
      --border-subtle: {{ theme.border_subtle if theme else '#1e2835' }};
      --radius-lg: {{ theme.radius_lg if theme else '12px' }};
      --radius-md: {{ theme.radius_md if theme else '8px' }};
      --shadow-soft: {{ theme.shadow_soft if theme else '0 18px 45px rgba(0, 0, 0, 0.55)' }};
      
      /* Fonts */
      --sans: {{ theme.font_sans if theme else '"Plus Jakarta Sans", system-ui, -apple-system, sans-serif' }};
      --mono: {{ theme.font_mono if theme else '"JetBrains Mono", "SF Mono", Consolas, monospace' }};
      
      /* Font weights for hierarchy */
      --weight-light: 300;
      --weight-normal: 400;
      --weight-medium: 500;
      --weight-semibold: 600;
      --weight-bold: 700;
    }
    
    /* Base styles */
    * { box-sizing: border-box; }
    
    body {
      margin: 0;
      padding: 0;
      font-family: var(--sans);
      font-weight: var(--weight-normal);
      font-size: 15px;
      line-height: 1.6;
      background: radial-gradient(circle at top left, var(--bg-soft) 0%, var(--bg-elevated) 45%, var(--bg) 100%);
      color: var(--text-main);
      -webkit-font-smoothing: antialiased;
      letter-spacing: -0.01em;
    }
    
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
  
  {# Core layout styles #}
  <style>
{% include "static/base.css" ignore missing %}
  </style>
  
  {# Plugin-specific styles #}
  <style>
{% include "static/plugin.css" ignore missing %}
  </style>
  
  {% block head_styles %}{% endblock %}
</head>
<body>
  <div class="page">
    {% block header %}
    <header>
      <h1>{{ config.title }}</h1>
      {% if meta_text %}
      <div class="meta"><span>{{ meta_text }}</span></div>
      {% endif %}
    </header>
    {% endblock %}
    
    {% block nav %}
    {% if nav_items %}
    <div class="nav-links">
      {% for item in nav_items %}
      <a href="{{ item.url }}"{% if item.active %} class="active"{% endif %}>{{ item.label }}</a>
      {% endfor %}
    </div>
    {% endif %}
    {% endblock %}
    
    {% block content %}{% endblock %}
    
    {% block footer %}
    <div class="footer">{{ labels.get('footer_text', 'Generated by BobReview') }}</div>
    {% endblock %}
  </div>
  
  {% block scripts %}{% endblock %}
</body>
</html>
