{#- Stat Card Component
    
    Parameters:
        label: Card title/label
        value: Main value to display
        subtitle: Optional subtitle text
        variant: CSS class variant ('ok', 'warn', 'danger', or empty)
-#}
{% macro stat_card(label, value, subtitle='', variant='') %}
<div class="stat-card{% if variant %} {{ variant }}{% endif %}">
  <div class="stat-label">{{ label }}</div>
  <div class="stat-value">{{ value }}</div>
  {% if subtitle %}
  <div class="stat-sub">{{ subtitle }}</div>
  {% endif %}
</div>
{% endmacro %}


{#- Stats Item Component (for stats grid)
    
    Parameters:
        label: Item label
        value: Item value
-#}
{% macro stats_item(label, value) %}
<div class="stats-item">
  <div class="stats-item-label">{{ label }}</div>
  <div class="stats-item-value">{{ value }}</div>
</div>
{% endmacro %}


{#- Trend Indicator Component
    
    Parameters:
        direction: 'improving', 'degrading', or 'stable'
        label: Text label for the trend
-#}
{% macro trend_indicator(direction, label) %}
<span class="trend-indicator {{ direction }}">
  <i class="fas fa-{{ direction|trend_icon }}"></i> {{ label }}
</span>
{% endmacro %}


{#- Pill Badge Component
    
    Parameters:
        text: Badge text
        variant: 'ok', 'warn', 'danger', or empty for default
-#}
{% macro pill(text, variant='') %}
<span class="pill{% if variant %} {{ variant }}{% endif %}">{{ text }}</span>
{% endmacro %}


{#- Percentile Badge Component
    
    Parameters:
        label: Percentile label (e.g., "P90")
        value: Percentile value
-#}
{% macro percentile_badge(label, value) %}
<span class="percentile-badge">{{ label }}: {{ value }}</span>
{% endmacro %}


{#- Feature Card Component (for navigation cards)
    
    Parameters:
        url: Link destination
        icon: FontAwesome icon class (e.g., 'fa-chart-bar')
        title: Card title
        description: Card description
        pills: Optional list of (text, variant) tuples
-#}
{% macro feature_card(url, icon, title, description, pills=None) %}
<a href="{{ url }}" style="text-decoration: none;">
  <div class="feature-card">
    <div class="icon"><i class="fas {{ icon }}"></i></div>
    <h3>{{ title }}</h3>
    <p style="flex-grow: 1;">{{ description }}</p>
    <div class="pill-row" style="margin-top: 12px; min-height: 26px;">
      {% if pills %}
      {% for text, variant in pills %}
      {{ pill(text, variant) }}
      {% endfor %}
      {% endif %}
    </div>
  </div>
</a>
{% endmacro %}


{#- Metric Table Component
    
    Parameters:
        metric_name: Display name for the metric
        stats: Dictionary with min, max, q1, median, q3, mean, stdev, variance, cv
        labels: Labels object with get() method
-#}
{% macro metric_table(metric_name, stats, labels) %}
<h3>{{ metric_name }}</h3>
<table>
  <thead>
    <tr>
      <th>{{ labels.get('metric', 'Metric') }}</th>
      <th>{{ labels.get('value', 'Value') }}</th>
    </tr>
  </thead>
  <tbody>
    <tr><td>{{ labels.get('minimum', 'Min') }}</td><td>{{ stats.min|format_number }}</td></tr>
    <tr><td>{{ labels.get('q1_label', 'Q1 (25th percentile)') }}</td><td>{{ stats.q1|format_number(0) }}</td></tr>
    <tr><td>{{ labels.get('q2_label', 'Median (50th percentile)') }}</td><td>{{ stats.median|format_number(0) }}</td></tr>
    <tr><td>{{ labels.get('q3_label', 'Q3 (75th percentile)') }}</td><td>{{ stats.q3|format_number(0) }}</td></tr>
    <tr><td>{{ labels.get('maximum', 'Max') }}</td><td>{{ stats.max|format_number }}</td></tr>
    <tr><td>{{ labels.get('mean', 'Mean') }}</td><td>{{ stats.mean|format_number(1) }}</td></tr>
    <tr><td>{{ labels.get('standard_deviation', 'Standard Deviation') }}</td><td>{{ stats.stdev|format_number(1) }}</td></tr>
    <tr><td>{{ labels.get('variance', 'Variance') }}</td><td>{{ stats.variance|format_number(1) }}</td></tr>
    <tr><td>{{ labels.get('cv', 'CV') }}</td><td>{{ stats.cv|format_number(1) }}%</td></tr>
  </tbody>
</table>
{% endmacro %}


{#- Performance Grade Component
    Shows a letter grade (A/B/C/D/F) based on budget utilization
    
    Parameters:
        value: Current value (e.g., draw calls)
        budget: Budget threshold (soft cap)
        label: Optional label for the grade
-#}
{% macro performance_grade(value, budget, label='') %}
{% set utilization = (value / budget * 100)|round(0)|int if budget > 0 else 100 %}
{% if utilization <= 50 %}
  {% set grade = 'A' %}
  {% set grade_class = 'grade-a' %}
{% elif utilization <= 75 %}
  {% set grade = 'B' %}
  {% set grade_class = 'grade-b' %}
{% elif utilization <= 90 %}
  {% set grade = 'C' %}
  {% set grade_class = 'grade-c' %}
{% elif utilization <= 100 %}
  {% set grade = 'D' %}
  {% set grade_class = 'grade-d' %}
{% else %}
  {% set grade = 'F' %}
  {% set grade_class = 'grade-f' %}
{% endif %}
<div class="performance-grade {{ grade_class }}">
  <div class="grade-letter">{{ grade }}</div>
  {% if label %}<div class="grade-label">{{ label }}</div>{% endif %}
  <div class="grade-detail">{{ utilization }}% of budget</div>
</div>
{% endmacro %}


{#- Budget Bar Component
    Shows a progress bar with color coding based on budget utilization
    
    Parameters:
        label: Metric name
        value: Current value
        budget: Budget threshold
        show_numbers: Whether to show numeric values
-#}
{% macro budget_bar(label, value, budget, show_numbers=true) %}
{% set utilization = (value / budget * 100)|round(0)|int if budget > 0 else 100 %}
{% set capped_width = [utilization, 100]|min %}
{% if utilization <= 75 %}
  {% set bar_class = 'budget-ok' %}
{% elif utilization <= 90 %}
  {% set bar_class = 'budget-warn' %}
{% elif utilization <= 100 %}
  {% set bar_class = 'budget-caution' %}
{% else %}
  {% set bar_class = 'budget-over' %}
{% endif %}
<div class="budget-row">
  <div class="budget-label">{{ label }}</div>
  <div class="budget-bar-container">
    <div class="budget-bar {{ bar_class }}" style="width: {{ capped_width }}%"></div>
    {% if utilization > 100 %}
    <div class="budget-over-indicator">+{{ utilization - 100 }}%</div>
    {% endif %}
  </div>
  {% if show_numbers %}
  <div class="budget-value">{{ value|format_number(0) }} / {{ budget|format_number(0) }}</div>
  {% endif %}
</div>
{% endmacro %}


{#- Hotspot Counter Component
    Shows count of performance issues with severity
    
    Parameters:
        hotspots: Number of hotspots
        optimized: Number of optimized frames
        total: Total frame count
-#}
{% macro hotspot_counter(hotspots, optimized, total) %}
<div class="hotspot-counter">
  <div class="hotspot-item danger">
    <span class="hotspot-count">{{ hotspots }}</span>
    <span class="hotspot-label">Hotspots</span>
  </div>
  <div class="hotspot-item ok">
    <span class="hotspot-count">{{ optimized }}</span>
    <span class="hotspot-label">Optimized</span>
  </div>
  <div class="hotspot-item neutral">
    <span class="hotspot-count">{{ total - hotspots - optimized }}</span>
    <span class="hotspot-label">Normal</span>
  </div>
</div>
{% endmacro %}


{#- Chart Explanation Component
    Extracts and displays explanation for a specific chart from chart_explanations string
    
    Parameters:
        explanations: HTML string containing all chart explanations
        chart_id: Chart ID to extract (e.g., 'draws_timeline')
-#}
{% macro chart_explanation(explanations, chart_id) %}
{% if explanations %}
  {% set start_marker = '<div data-chart="' ~ chart_id ~ '">' %}
  {% set end_marker = '</div>' %}
  {% set start_pos = explanations.find(start_marker) %}
  {% if start_pos >= 0 %}
    {% set content_start = start_pos + start_marker|length %}
    {% set content_end = explanations.find(end_marker, content_start) %}
    {% if content_end >= 0 %}
      <div class="chart-explanation">{{ explanations[content_start:content_end]|safe }}</div>
    {% endif %}
  {% endif %}
{% endif %}
{% endmacro %}