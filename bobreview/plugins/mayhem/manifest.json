{
    "name": "MayhemAutomation",
    "version": "1.0.0",
    "author": "BobReview Team",
    "description": "Full-featured automation: LLM generators, themes, services, templates, and report systems.",
    "entry_point": "plugin:MayhemAutomationPlugin",
    "dependencies": [],
    "provides": [
        "llm-generators",
        "data-parsers",
        "themes",
        "services",
        "report-systems",
        "templates"
    ],
    "min_bobreview_version": "1.0.7",
    "config_schema": {
        "type": "object",
        "properties": {
            "register_themes": {
                "type": "boolean",
                "default": true,
                "description": "Register all 7 built-in themes"
            },
            "register_generators": {
                "type": "boolean",
                "default": true,
                "description": "Register built-in LLM generators"
            },
            "register_services": {
                "type": "boolean",
                "default": true,
                "description": "Register default service implementations"
            },
            "register_report_systems": {
                "type": "boolean",
                "default": true,
                "description": "Register built-in report systems"
            },
            "register_templates": {
                "type": "boolean",
                "default": true,
                "description": "Register built-in templates"
            }
        }
    }
}