{% extends "base.html.j2" %}

{% block title %}{{ game.name }} - Review{% endblock %}

{% block head_styles %}
<style>
{% include "static/plugin.css" ignore missing %}
</style>
{% endblock %}

{% block body %}
<!-- Hero -->
<section class="hero">
    {% if game.cover_image %}
    <img src="{{ game.cover_image }}" alt="{{ game.name }}" class="hero-bg">
    {% else %}
    <div class="hero-bg" style="background: linear-gradient(135deg, var(--accent), var(--accent-strong));"></div>
    {% endif %}
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <div class="game-meta">
            {% if game.genre %}<span class="meta-tag">{{ game.genre }}</span>{% endif %}
        </div>
        <h1 class="game-title">{{ game.name }}</h1>
        {% if game.my_review %}
        <p class="game-tagline">"{{ game.my_review }}"</p>
        {% endif %}
    </div>
</section>

<div class="container">
    <div class="review-layout">
        <div class="review-content">
            
            <!-- Full Review -->
            {% if llm_content and llm_content.full_review %}
            <section class="section">
                <h2>
                    <svg class="section-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
                    Our Review
                </h2>
                <div class="review-text">
                    {{ llm_content.full_review|sanitize }}
                </div>
            </section>
            {% endif %}
            
            <!-- Pros & Cons -->
            <section class="pros-cons">
                <div class="pros-section">
                    <h3 class="section-title good">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                        What We Loved
                    </h3>
                    {% if llm_content and llm_content.expanded_pros %}
                    <div class="review-text">{{ llm_content.expanded_pros|sanitize }}</div>
                    {% else %}
                    <ul class="list">
                        {% for item in game.what_i_liked %}
                        <li>{{ item }}</li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                </div>
                
                <div class="cons-section">
                    <h3 class="section-title bad">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/></svg>
                        Room For Improvement
                    </h3>
                    {% if llm_content and llm_content.expanded_cons %}
                    <div class="review-text">{{ llm_content.expanded_cons|sanitize }}</div>
                    {% elif game.needs_improvement %}
                    <ul class="list">
                        {% for item in game.needs_improvement %}
                        <li>{{ item }}</li>
                        {% endfor %}
                    </ul>
                    {% else %}
                    <p class="review-text">No significant issues noted.</p>
                    {% endif %}
                </div>
            </section>
            
            <!-- Target Audience -->
            {% if llm_content and llm_content.target_audience %}
            <section class="section audience-section">
                <h2>
                    <svg class="section-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                    Perfect For
                </h2>
                <div class="review-text">{{ llm_content.target_audience|sanitize }}</div>
            </section>
            {% endif %}
            
            <!-- Similar Games -->
            {% if llm_content and llm_content.similar_games %}
            <section class="section">
                <h2>
                    <svg class="section-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M21 6h-7.59l3.29-3.29L16 2l-4 4-4-4-.71.71L10.59 6H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 14H3V8h18v12zM9 10v8l7-4z"/></svg>
                    If You Liked This, Try...
                </h2>
                <div class="review-text">{{ llm_content.similar_games|sanitize }}</div>
            </section>
            {% endif %}
            
            <!-- Screenshots -->
            {% if game.screenshots and game.screenshots|length > 0 %}
            <section class="section">
                <h2>
                    <svg class="section-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                    Screenshots
                </h2>
                <div class="screenshot-grid">
                    {% for screenshot in game.screenshots %}
                    <img src="{{ screenshot }}" alt="{{ game.name }} Screenshot">
                    {% endfor %}
                </div>
            </section>
            {% endif %}
            
            <!-- Verdict -->
            {% if llm_content and llm_content.verdict %}
            <section class="verdict-box">
                <h3>The Verdict</h3>
                <p class="verdict-text">{{ llm_content.verdict }}</p>
            </section>
            {% endif %}
            
            <!-- Original User Notes -->
            {% if game.my_review %}
            <div class="user-notes">
                <h4>Reviewer's Quick Take</h4>
                <p>{{ game.my_review }}</p>
            </div>
            {% endif %}
            
        </div>
        
        <!-- Sidebar - Scores -->
        <aside>
            <div class="score-card">
                {% set score = game.my_score|default(7) %}
                <div class="score-number">{{ score }}</div>
                <div class="score-label">Overall</div>
                {% if score >= 9 %}
                <div class="score-verdict">Masterpiece</div>
                {% elif score >= 8 %}
                <div class="score-verdict">Excellent</div>
                {% elif score >= 7 %}
                <div class="score-verdict">Great</div>
                {% elif score >= 6 %}
                <div class="score-verdict">Good</div>
                {% elif score >= 5 %}
                <div class="score-verdict">Average</div>
                {% else %}
                <div class="score-verdict">Below Average</div>
                {% endif %}
            </div>
            
            {% if game.scores %}
            <div class="category-scores" style="margin-top: 1.5rem;">
                {% set categories = [
                    ('Gameplay', game.scores.gameplay|default(0)),
                    ('Graphics', game.scores.graphics|default(0)),
                    ('Story', game.scores.story|default(0)),
                    ('Sound', game.scores.sound|default(0)),
                    ('Value', game.scores.value|default(0))
                ] %}
                {% for name, cat_score in categories %}
                {% if cat_score > 0 %}
                <div class="category" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
                    <span style="width: 70px; font-size: 0.75rem; color: var(--text-secondary);">{{ name }}</span>
                    <div style="flex: 1; height: 8px; background: var(--bg-soft); border-radius: 4px; overflow: hidden;">
                        {% if cat_score >= 9 %}{% set bar_color = 'var(--success)' %}
                        {% elif cat_score >= 7 %}{% set bar_color = '#7dd87d' %}
                        {% elif cat_score >= 5 %}{% set bar_color = 'var(--warning)' %}
                        {% else %}{% set bar_color = 'var(--danger)' %}{% endif %}
                        <div style="width: {{ cat_score * 10 }}%; height: 100%; background: {{ bar_color }}; border-radius: 4px;"></div>
                    </div>
                    <span style="width: 20px; font-size: 0.8rem; font-weight: 600;">{{ cat_score }}</span>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            {% endif %}
        </aside>
    </div>
    
    <footer style="text-align: center; padding: 2rem 0; color: var(--text-secondary); font-size: 0.875rem; border-top: 1px solid var(--border); margin-top: 2rem;">
        <p>Review generated by BobReview • {{ game.name }} • Score: {{ game.my_score|default(7) }}/10</p>
    </footer>
</div>
{% endblock %}
