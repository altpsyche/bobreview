<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{% block title %}{{ config.title if config and config.title else 'Review' }}{% endblock %}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  {% block head_scripts %}{% endblock %}
  
  <style>
    /* Theme CSS Variables - aligned with core CSS naming */
    :root {
      /* Backgrounds */
      --bg: {{ theme.bg if theme else '#0f0f0f' }};
      --bg-elevated: {{ theme.bg_elevated if theme else '#1a1a1a' }};
      --bg-soft: {{ theme.bg_soft if theme else '#242424' }};
      
      /* Accents */
      --accent: {{ theme.accent if theme else '#ff6b35' }};
      --accent-soft: {{ theme.accent_soft if theme else 'rgba(255, 107, 53, 0.15)' }};
      --accent-strong: {{ theme.accent_strong if theme else '#ff8f6b' }};
      
      /* Text */
      --text-main: {{ theme.text_main if theme else '#ffffff' }};
      --text-soft: {{ theme.text_soft if theme else '#a0a0a0' }};
      
      /* Status */
      --ok: {{ theme.ok if theme else '#00d26a' }};
      --ok-soft: {{ theme.ok_soft if theme else 'rgba(0, 210, 106, 0.15)' }};
      --warn: {{ theme.warn if theme else '#ffc107' }};
      --warn-soft: {{ theme.warn_soft if theme else 'rgba(255, 193, 7, 0.15)' }};
      --danger: {{ theme.danger if theme else '#ff4444' }};
      --danger-soft: {{ theme.danger_soft if theme else 'rgba(255, 68, 68, 0.15)' }};
      
      /* Border & Effects */
      --border-subtle: {{ theme.border_subtle if theme else '#333333' }};
      --radius-lg: {{ theme.radius_lg if theme else '12px' }};
      --radius-md: {{ theme.radius_md if theme else '8px' }};
      --shadow-soft: {{ theme.shadow_soft if theme else '0 18px 45px rgba(0, 0, 0, 0.55)' }};
      
      /* Fonts */
      --sans: {{ theme.font_sans if theme else "'Inter', -apple-system, sans-serif" }};
      --mono: {{ theme.font_mono if theme else "'JetBrains Mono', monospace" }};
    }
    
    /* Base styles */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text-main);
      line-height: 1.6;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
    }
    
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    
    .card {
      background: var(--bg-elevated);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      border: 1px solid var(--border-subtle);
    }
    
    .btn {
      background: var(--accent);
      color: var(--text-main);
      padding: 0.75rem 1.5rem;
      border-radius: var(--radius-md);
      border: none;
      cursor: pointer;
      font-weight: 600;
    }
    
    .btn:hover { opacity: 0.9; }
    
    .status-ok { color: var(--ok); }
    .status-warn { color: var(--warn); }
    .status-danger { color: var(--danger); }
  </style>
  
  {% block head_styles %}{% endblock %}
</head>
<body>
  {% block body %}
  <div class="container">
    {% block header %}{% endblock %}
    {% block content %}{% endblock %}
    {% block footer %}
    <footer style="text-align: center; padding: 2rem 0; color: var(--text-secondary); font-size: 0.875rem; border-top: 1px solid var(--border); margin-top: 3rem;">
      {{ labels.footer_text if labels else 'Generated by BobReview' }}
    </footer>
    {% endblock %}
  </div>
  {% endblock %}
  
  {% block scripts %}{% endblock %}
</body>
</html>
