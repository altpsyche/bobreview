{% extends "base.html.j2" %}
{% from "components/macros.html.j2" import metric_table, stats_item %}

{% block title %}{{ config.title }} - {{ labels.statistical_summary }}{% endblock %}

{% block content %}
{# Set up dynamic metrics - use JSON config with fallback to draws/tris #}
{% set primary_metric = metrics[0] if metrics else 'draws' %}
{% set secondary_metric = metrics[1] if metrics|length > 1 else 'tris' %}
{% set primary_label = metric_labels.get(primary_metric, labels.draw_calls) if metric_labels else labels.draw_calls %}
{% set secondary_label = metric_labels.get(secondary_metric, labels.triangles) if metric_labels else labels.triangles %}
{% set primary_stats = stats[primary_metric] if primary_metric in stats else stats.draws %}
{% set secondary_stats = stats[secondary_metric] if secondary_metric in stats else stats.tris %}
{% set identifier_field = metrics.identifier_field if metrics.identifier_field is defined else 'testcase' %}

<section class="panel">
  <h2>{{ labels.statistical_summary }}</h2>
  
  {{ llm.stats_interpretation|sanitize }}
</section>

<!-- Complete Statistics -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ primary_label }} {{ labels.get('complete_stats', 'Complete Statistics') }}</h2>
  {{ metric_table(primary_label, primary_stats, labels) }}
</section>

<section class="panel" style="margin-top: 20px;">
  <h2>{{ secondary_label }} {{ labels.get('complete_stats', 'Complete Statistics') }}</h2>
  {{ metric_table(secondary_label, secondary_stats, labels) }}
</section>

<!-- Outlier Analysis -->
{% if stats.outliers %}
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('outlier_analysis', 'Outlier Analysis') }}</h2>
  <p class="body-text">{{ labels.get('outlier_desc', 'Data points significantly deviating from the mean:') }}</p>
  
  <div class="stats-grid">
    {{ stats_item(labels.get('outliers_detected', 'Outliers Detected'), stats.outliers|length) }}
    {{ stats_item(labels.get('detection_method', 'Detection Method'), labels.get('zscore', 'Z-Score (σ=' ~ config.outlier_sigma ~ ')')) }}
  </div>
  
  <table style="margin-top: 16px;">
    <thead>
      <tr>
        <th>{{ labels.index }}</th>
        <th>{{ labels.testcase }}</th>
        <th>{{ primary_label }}</th>
        <th>{{ secondary_label }}</th>
        <th>{{ labels.get('zscore', 'Z-Score') }}</th>
      </tr>
    </thead>
    <tbody>
      {% for outlier in stats.outliers[:15] %}
      <tr>
        <td>{{ outlier.index }}</td>
        <td>{{ outlier[identifier_field]|default(outlier.testcase) }}</td>
        <td>{{ outlier[primary_metric]|default(outlier.draws) }}</td>
        <td>{{ outlier[secondary_metric]|default(outlier.tris)|format_number }}</td>
        <td>{{ outlier.zscore|format_number(2) if outlier.zscore else 'N/A' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

<!-- Confidence Intervals -->
{% if primary_stats.ci_lower is defined and primary_stats.ci_upper is defined %}
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('confidence_intervals', 'Confidence Intervals') }}</h2>
  
  <div class="stats-grid">
    {{ stats_item(primary_label ~ ' 95% CI', (primary_stats.ci_lower|format_number(1)) ~ ' - ' ~ (primary_stats.ci_upper|format_number(1))) }}
    {{ stats_item(secondary_label ~ ' 95% CI', (secondary_stats.ci_lower|default(0)|format_number(0)) ~ ' - ' ~ (secondary_stats.ci_upper|default(0)|format_number(0))) }}
  </div>
</section>
{% endif %}

<!-- Full Data Table -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.full_sample_table }}</h2>
  <p class="body-text">{{ labels.get('all_captures', 'All captured data points:') }}</p>
  
  <table>
    <thead>
      <tr>
        <th>{{ labels.index }}</th>
        <th>{{ labels.testcase }}</th>
        <th>{{ primary_label }}</th>
        <th>{{ secondary_label }}</th>
        <th>{{ labels.timestamp }}</th>
        {% if has_images %}
        <th>{{ labels.screenshot }}</th>
        {% endif %}
      </tr>
    </thead>
    <tbody>
      {% for point in data_points %}
      <tr>
        <td>{{ loop.index0 }}</td>
        <td>{{ point[identifier_field]|default(point.testcase) }}</td>
        <td>{{ point[primary_metric]|default(point.draws) }}</td>
        <td>{{ point[secondary_metric]|default(point.tris)|format_number }}</td>
        <td>{{ point.ts }}</td>
        {% if has_images %}
        <td>
          {% if images[loop.index0] is defined %}
          <img src="{{ images[loop.index0].src }}" alt="{{ point[identifier_field]|default(point.testcase) }}" class="thumb-small" loading="lazy" />
          {% else %}-{% endif %}
        </td>
        {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endblock %}
