{% extends "base.html.j2" %}
{% from "components/macros.html.j2" import stat_card, stats_item, trend_indicator, pill, percentile_badge, feature_card %}

{% block title %}{{ config.title }} - {{ labels.home }}{% endblock %}

{% block head_scripts %}{% endblock %}

{% block content %}
{# Set up dynamic metrics - use JSON config with fallback to draws/tris #}
{% set primary_metric = metrics[0] if metrics else 'draws' %}
{% set secondary_metric = metrics[1] if metrics|length > 1 else 'tris' %}
{% set primary_label = metric_labels.get(primary_metric, labels.draw_calls) if metric_labels else labels.draw_calls %}
{% set secondary_label = metric_labels.get(secondary_metric, labels.triangles) if metric_labels else labels.triangles %}
{% set primary_stats = stats[primary_metric] if primary_metric in stats else stats.draws %}
{% set secondary_stats = stats[secondary_metric] if secondary_metric in stats else stats.tris %}

<!-- Executive Summary Section -->
<section class="panel">
  <h2>{{ labels.executive_summary }}</h2>
  
  <div class="summary-grid">
    {{ stat_card(
        labels.average,
        (primary_stats.mean|format_number(0)) ~ ' ' ~ primary_label,
        (secondary_stats.mean|format_number(0)) ~ ' ' ~ secondary_label ~ ' · ' ~ labels.median ~ ' ' ~ (primary_stats.median|format_number(0)) ~ ' / ' ~ (secondary_stats.median|format_number(0)),
        'ok'
    ) }}
    
    {{ stat_card(
        labels.peak_hotspot,
        critical[primary_metric]|default(critical.draws) ~ ' ' ~ primary_label,
        (critical[secondary_metric]|default(critical.tris)|format_number) ~ ' ' ~ secondary_label ~ ' (index ' ~ critical.index ~ ')',
        'danger'
    ) }}
    
    {{ stat_card(
        labels.high_load_frames,
        stats.high_load|length,
        primary_label ~ ' ≥ ' ~ config.high_load_draw_threshold ~ ' or ' ~ secondary_label ~ ' ≥ ' ~ (config.high_load_tri_threshold|format_number(0)),
        'warn'
    ) }}
  </div>
  
  <div style="margin-top: 12px;">
    {{ percentile_badge(labels.p90 ~ ' ' ~ primary_label, primary_stats.p90|format_number(0)) }}
    {{ percentile_badge(labels.p95 ~ ' ' ~ primary_label, primary_stats.p95|format_number(0)) }}
    {{ percentile_badge(labels.p99 ~ ' ' ~ primary_label, primary_stats.p99|format_number(0)) }}
    {{ percentile_badge(labels.p90 ~ ' ' ~ secondary_label, secondary_stats.p90|format_number(0)) }}
    {{ percentile_badge(labels.p95 ~ ' ' ~ secondary_label, secondary_stats.p95|format_number(0)) }}
  </div>
  
  <div style="margin-top: 8px;">
    {% if stats.trends is defined and stats.trends[primary_metric] is defined %}
    <span style="font-size: 12px; color: var(--text-soft);">{{ labels.trend }}: </span>
    {{ trend_indicator(stats.trends[primary_metric].direction|default('stable'), (stats.trends[primary_metric].direction|default('stable')|title) ~ ' ' ~ primary_label) }}
    {{ trend_indicator(stats.trends[secondary_metric].direction|default('stable'), (stats.trends[secondary_metric].direction|default('stable')|title) ~ ' ' ~ secondary_label) }}
    {% endif %}
    <span style="font-size: 12px; color: var(--text-soft); margin-left: 8px;">{{ labels.cv }}: {{ primary_stats.cv|format_number(1) }}% {{ primary_label }} / {{ secondary_stats.cv|format_number(1) }}% {{ secondary_label }}</span>
  </div>
  
  {{ llm.exec_summary|sanitize }}
  
  <div class="pill-row">
    {{ pill(labels.average ~ ': ' ~ (primary_stats.mean|format_number(0)) ~ ' ' ~ primary_label ~ ' / ' ~ (secondary_stats.mean|format_number(0)) ~ ' ' ~ secondary_label, 'ok') }}
    {% if primary_stats.cv > 30 or secondary_stats.cv > 30 %}
    {{ pill(labels.get('high_variance_detected', 'High variance detected'), 'warn') }}
    {% endif %}
    {{ pill(labels.peak_hotspot ~ ': ' ~ critical[primary_metric]|default(critical.draws) ~ ' ' ~ primary_label ~ ' / ' ~ (critical[secondary_metric]|default(critical.tris)|format_number) ~ ' ' ~ secondary_label, 'danger') }}
  </div>
</section>

<!-- Navigation Cards -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.detailed_analysis }}</h2>
  <p class="body-text">{{ labels.get('explore_sections', 'Explore different aspects of the performance analysis:') }}</p>
  
  <div class="card-grid">
    {% for page in pages if page.id != 'home' and page.card_description %}
    {% set page_pills = [] %}
    {% if page.id == 'zones' %}
      {% set page_pills = [(stats.high_load|length ~ ' ' ~ labels.high_load, 'danger'), (stats.low_load|length ~ ' ' ~ labels.low_load, 'ok')] %}
    {% endif %}
    {{ feature_card(page.filename, page.card_icon, page.nav_label, page.card_description, page_pills) }}
    {% endfor %}
  </div>
</section>

<!-- Quick Stats Section -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.quick_stats }}</h2>
  
  <div class="stats-grid">
    {{ stats_item(labels.total_captures, stats.count) }}
    {{ stats_item(primary_label ~ ' ' ~ labels.range_label, primary_stats.min ~ ' - ' ~ primary_stats.max) }}
    {{ stats_item(secondary_label ~ ' ' ~ labels.range_label, (secondary_stats.min|format_number) ~ ' - ' ~ (secondary_stats.max|format_number)) }}
    {{ stats_item(labels.high_load_frames, stats.high_load|length) }}
    {{ stats_item(labels.low_load_frames, stats.low_load|length) }}
    {{ stats_item(labels.performance_variance, (primary_stats.cv|format_number(1)) ~ '%') }}
  </div>
</section>
{% endblock %}
