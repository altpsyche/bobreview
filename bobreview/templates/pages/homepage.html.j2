{% extends "base.html.j2" %}
{% from "components/macros.html.j2" import stat_card, stats_item, trend_indicator, pill, percentile_badge, feature_card %}

{% block title %}{{ config.title }} - {{ labels.get('home', 'Home') }}{% endblock %}

{% block head_scripts %}{% endblock %}

{% block content %}
{# Build combined context for interpolation - includes stats, config, critical, and computed values #}
{% set ctx = {
  'stats': stats,
  'critical': critical,
  'high_load_draw_threshold': config.high_load_draw_threshold,
  'high_load_tri_threshold': config.high_load_tri_threshold,
  'low_load_draw_threshold': config.low_load_draw_threshold,
  'low_load_tri_threshold': config.low_load_tri_threshold
} %}

<!-- Executive Summary Section -->
<section class="panel">
  <h2>{{ labels.get('executive_summary', 'Executive Summary') }}</h2>
  
  <div class="summary-grid">
    {# Data-driven summary cards from JSON #}
    {% if content.summary_cards %}
    {% for card in content.summary_cards %}
    <div class="stat-card {{ card.variant|default('ok') }}">
      <div class="stat-label">{{ card.label }}</div>
      <div class="stat-value">{{ card.value|interpolate(ctx) }}</div>
      <div class="stat-sub">{{ card.sub|interpolate(ctx) }}</div>
    </div>
    {% endfor %}
    {% else %}
    {# Fallback for backward compatibility #}
    {{ stat_card('Average', stats.draws.mean|format_number(0) ~ ' Draw Calls', stats.tris.mean|format_number(0) ~ ' Triangles', 'ok') }}
    {{ stat_card('Peak Hotspot', critical.draws ~ ' Draw Calls', critical.tris|format_number ~ ' Triangles', 'danger') }}
    {{ stat_card('High-Load Frames', stats.high_load|length, 'Frames exceeding thresholds', 'warn') }}
    {% endif %}
  </div>
  
  <div style="margin-top: 12px;">
    {{ percentile_badge(labels.get('p90', 'P90') ~ ' Draws', stats.draws.p90|format_number(0)) }}
    {{ percentile_badge(labels.get('p95', 'P95') ~ ' Draws', stats.draws.p95|format_number(0)) }}
    {{ percentile_badge(labels.get('p99', 'P99') ~ ' Draws', stats.draws.p99|format_number(0)) }}
    {{ percentile_badge(labels.get('p90', 'P90') ~ ' Tris', stats.tris.p90|format_number(0)) }}
    {{ percentile_badge(labels.get('p95', 'P95') ~ ' Tris', stats.tris.p95|format_number(0)) }}
  </div>
  
  <div style="margin-top: 8px;">
    {% if stats.trends is defined and stats.trends.draws is defined %}
    <span style="font-size: 12px; color: var(--text-soft);">{{ labels.get('trend', 'Trend') }}: </span>
    {{ trend_indicator(stats.trends.draws.direction|default('stable'), (stats.trends.draws.direction|default('stable')|title) ~ ' Draws') }}
    {{ trend_indicator(stats.trends.tris.direction|default('stable'), (stats.trends.tris.direction|default('stable')|title) ~ ' Tris') }}
    {% endif %}
    <span style="font-size: 12px; color: var(--text-soft); margin-left: 8px;">CV: {{ stats.draws.cv|format_number(1) }}% Draws / {{ stats.tris.cv|format_number(1) }}% Tris</span>
  </div>
  
  {{ llm.exec_summary|sanitize }}
  
  <div class="pill-row">
    {{ pill('Average: ' ~ (stats.draws.mean|format_number(0)) ~ ' Draws / ' ~ (stats.tris.mean|format_number(0)) ~ ' Tris', 'ok') }}
    {% if stats.draws.cv > 30 or stats.tris.cv > 30 %}
    {{ pill(labels.get('high_variance_detected', 'High variance detected'), 'warn') }}
    {% endif %}
    {{ pill('Peak: ' ~ critical.draws ~ ' Draws / ' ~ (critical.tris|format_number) ~ ' Tris', 'danger') }}
  </div>
</section>

<!-- Navigation Cards -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('detailed_analysis', 'Detailed Analysis') }}</h2>
  <p class="body-text">{{ content.explore_sections|default('Explore different aspects of the performance analysis:') }}</p>
  
  <div class="card-grid">
    {% for page in pages if page.id != 'home' and page.card_description %}
    {% set page_pills = [] %}
    {% if page.id == 'zones' %}
      {% set page_pills = [(stats.high_load|length ~ ' High-Load', 'danger'), (stats.low_load|length ~ ' Low-Load', 'ok')] %}
    {% endif %}
    {{ feature_card(page.filename, page.card_icon, page.nav_label, page.card_description, page_pills) }}
    {% endfor %}
  </div>
</section>

<!-- Quick Stats Section -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('quick_stats', 'Quick Statistics') }}</h2>
  
  <div class="stats-grid">
    {# Data-driven quick stats from JSON #}
    {% if content.quick_stats %}
    {% for item in content.quick_stats %}
    <div class="stats-item">
      <div class="stats-item-label">{{ item.label }}</div>
      <div class="stats-item-value">{{ item.value|interpolate(ctx) }}</div>
    </div>
    {% endfor %}
    {% else %}
    {# Fallback #}
    {{ stats_item('Total Captures', stats.count) }}
    {{ stats_item('Draw Calls Range', stats.draws.min ~ ' - ' ~ stats.draws.max) }}
    {{ stats_item('Triangles Range', (stats.tris.min|format_number) ~ ' - ' ~ (stats.tris.max|format_number)) }}
    {{ stats_item('High-Load Frames', stats.high_load|length) }}
    {{ stats_item('Low-Load Frames', stats.low_load|length) }}
    {{ stats_item('Performance Variance', (stats.draws.cv|format_number(1)) ~ '%') }}
    {% endif %}
  </div>
</section>
{% endblock %}

