{% extends "base.html.j2" %}
{% from "components/macros.html.j2" import stat_card %}

{% block title %}{{ config.title }} - {{ labels.performance_zones }}{% endblock %}

{% block content %}
{# Calculate zone counts #}
{% set high_pct = (stats.high_load|length / stats.count * 100) if stats.count > 0 else 0 %}
{% set low_pct = (stats.low_load|length / stats.count * 100) if stats.count > 0 else 0 %}
{% set medium_count = stats.count - stats.high_load|length - stats.low_load|length %}

<section class="panel">
  <h2>{{ labels.get('zones_overview', 'Performance Zones Overview') }}</h2>
  <p class="body-text">
    Performance zones categorize captures based on their resource usage. This helps identify 
    problematic areas requiring optimization and establish baseline performance expectations.
  </p>
  
  <div class="summary-grid">
    {{ stat_card(labels.high_load_frames, stats.high_load|length, (high_pct|format_number(1)) ~ '% of captures', 'danger') }}
    {{ stat_card(labels.get('medium_load_frames', 'Medium-Load Frames'), medium_count, 'Between thresholds', 'warn') }}
    {{ stat_card(labels.low_load_frames, stats.low_load|length, (low_pct|format_number(1)) ~ '% of captures', 'ok') }}
  </div>
</section>

<!-- High-Load Frames -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.high_load }} {{ labels.get('frames', 'Frames') }}</h2>
  <p class="body-text">
    High-load is defined as <strong>{{ labels.draw_calls }} ≥ {{ config.high_load_draw_threshold }}</strong> or
    <strong>{{ labels.triangles }} ≥ {{ config.high_load_tri_threshold|format_number(0) }}</strong>.
    These frames require immediate attention and optimization.
  </p>
  
  {{ llm.zones_analysis|sanitize }}
  
  <table>
    <thead>
      <tr>
        <th>{{ labels.index }}</th>
        <th>{{ labels.draw_calls }}</th>
        <th>{{ labels.triangles }}</th>
        <th>{{ labels.get('image', 'Image') }}</th>
      </tr>
    </thead>
    <tbody>
      {% if stats.high_load %}
        {% for frame in stats.high_load %}
        {% set idx = frame[0] %}
        {% set data = frame[1] %}
        <tr>
          <td>{{ idx }}</td>
          <td>{{ data.draws }}</td>
          <td>{{ data.tris|format_number }}</td>
          <td>
            {{ data.img|default('N/A') }}
            {% if data.img is defined and data.img and images[idx] is defined %}
            <img class="thumb-small" src="{{ images[idx].src }}" alt="Index {{ idx }} high-load frame">
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      {% else %}
        <tr>
          <td colspan="4" style="text-align: center; font-style: italic;">No high-load frames detected</td>
        </tr>
      {% endif %}
    </tbody>
  </table>
</section>

<!-- Low-Load Baselines -->
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('low_load_baselines', 'Low-Load Baselines') }}</h2>
  <p class="body-text">
    Low-load frames (<strong>{{ labels.draw_calls }} &lt; {{ config.low_load_draw_threshold }}</strong> and 
    <strong>{{ labels.triangles }} &lt; {{ config.low_load_tri_threshold|format_number(0) }}</strong>)
    represent baseline performance and are useful design references for optimal scenes.
  </p>
  
  <table>
    <thead>
      <tr>
        <th>{{ labels.index }}</th>
        <th>{{ labels.draw_calls }}</th>
        <th>{{ labels.triangles }}</th>
        <th>{{ labels.get('image', 'Image') }}</th>
      </tr>
    </thead>
    <tbody>
      {% if stats.low_load %}
        {% for frame in stats.low_load %}
        {% set idx = frame[0] %}
        {% set data = frame[1] %}
        <tr>
          <td>{{ idx }}</td>
          <td>{{ data.draws }}</td>
          <td>{{ data.tris|format_number }}</td>
          <td>
            {{ data.img|default('N/A') }}
            {% if data.img is defined and data.img and images[idx] is defined %}
            <img class="thumb-small" src="{{ images[idx].src }}" alt="Index {{ idx }} low-load frame">
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      {% else %}
        <tr>
          <td colspan="4" style="text-align: center; font-style: italic;">No low-load frames detected</td>
        </tr>
      {% endif %}
    </tbody>
  </table>
</section>

<!-- Critical Hotspot -->
{% if stats.count > 0 and critical %}
<section class="panel" style="margin-top: 20px;">
  <h2>{{ labels.get('critical_hotspot', 'Critical Hotspot') }}</h2>
  <p class="body-text">
    The single worst-performing capture that demands the highest priority for optimization work.
  </p>
  
  <div class="callout critical">
    <div class="callout-title">{{ labels.index }} {{ critical.index }}{% if data_points[critical.index] is defined %} - {{ data_points[critical.index].img|default('') }}{% endif %}</div>
    <div>{{ critical.draws }} {{ labels.draw_calls }} &middot; {{ critical.tris|format_number }} {{ labels.triangles }}</div>
  </div>
  
  {% if images[critical.index] is defined %}
  <img
    class="thumb-large"
    src="{{ images[critical.index].src }}"
    alt="Critical hotspot frame (index {{ critical.index }})"
    style="max-width: 100%;"
  />
  {% endif %}
  
  <div class="body-text">
    <strong>{{ labels.get('analysis', 'Analysis') }}:</strong> This frame represents the peak load in the capture session. 
    Focus optimization efforts here first, as improvements will have the most significant impact.
  </div>
</section>
{% endif %}
{% endblock %}
